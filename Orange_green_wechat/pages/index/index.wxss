/**index.wxss**/
.page-container{
  padding: 30rpx;
}

.header{
  background-color: #3d7ef9;
  color: #ffff;
  border-radius: 20px;
  padding: 26px 20px;
}

.header .header-air{
  display: flex;
  justify-content: space-between;
  font-size: 15px;
}

.header .header-title{
  display: flex;
  justify-content: space-between;
  font-size: 30px;
}

.header .header-ad{
  margin-top: 10px;
  font-size: 15px;
}

.data-container{
  /*background-color: rgb(226, 192, 192);*/
  margin-top: 15px;
  display: grid;
  justify-content: center;
  grid-template-columns: repeat(auto-fill,300rpx);
  grid-gap: 36rpx;
}

.data-container .data-card {
  background-color: #ffff;
  height: 50px;
  box-shadow: #d6d6d6 0 0 8rpx;
  border-radius: 36rpx;
  display: flex;
  justify-content: space-between;
  padding: 10px;
}

.data-container .data-card .data-card_icon{
  height: 72rpx;
  width: 72rpx;
}

.data-container .data-card .data-card_title{
  font-size: 35rpx;
  color: #7f7f7f;
}

.data-container .data-card .data-card_value{
font-size: 100rpx;
font-weight: bold;
}